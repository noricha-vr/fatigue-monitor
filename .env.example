# Required: Gemini API key for fatigue evaluation (LLM scoring)
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Discord Webhook URL for notifications
# Create one at: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: Thresholds (defaults shown)
# FATIGUE_THRESHOLD=7.0
# MIN_MESSAGES=3
# PROMPT_LENGTH_DROP_RATIO=0.3
# SESSION_LONG_MIN=180
# LATE_NIGHT_HOUR_START=22
# LATE_NIGHT_HOUR_END=5
